# App
APP_NAME=nest-fastify-app
APP_DESCRIPTION=Nest Fastify API Service
APP_VERSION=1.0.0
APP_ENV=development
APP_PORT=3000

# Database client: postgres | mysql | sqlite | nosql
DB_CLIENT=postgres

# Common SQL configuration
DB_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=app_db
DB_SSL=false

# SQLite-specific configuration
DB_SQLITE_FILE=./data/app.db

# NoSQL configuration (used when DB_CLIENT=nosql)
NOSQL_PROVIDER=mongodb
NOSQL_URI=mongodb://localhost:27017
NOSQL_DATABASE=app_nosql_db
